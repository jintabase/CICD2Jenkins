APP_NAME=blog-api
APP_HOST=0.0.0.0
APP_PORT=8080
APP_READ_TIMEOUT=5s
APP_WRITE_TIMEOUT=10s
APP_IDLE_TIMEOUT=60s

JWT_SECRET=replace-this-in-production
JWT_TTL=24h

DB_DRIVER=sqlite
DB_DSN=blog-api.db
# 如果你想切换成 MySQL：
# DB_DRIVER=mysql
# DB_DSN=blog:blog@tcp(127.0.0.1:3306)/blog_api?charset=utf8mb4&parseTime=True&loc=Local

SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=Admin@123456
READER_USERNAME=reader
READER_PASSWORD=Reader@123456
